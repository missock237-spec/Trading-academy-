    color: var(--text-secondary);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.3px;
    transition: color 0.2s;
    cursor: pointer;
  }
  .nav-links a:hover { color: var(--text-primary); }

